# Docker PostgreSQL
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=strapi_password

# Backend (Strapi)
HOST=0.0.0.0
PORT=1337
FRONTEND_ORIGIN=http://localhost:5173
EMBED_ALLOWED_ORIGIN=*
SEED_MVP_DATA=false
MANAGER_ALLOWED_EMAILS=2102maksim2004@gmail.com
PUBLIC_WRITE_AUTH_MODE=auth
PUBLIC_ACTOR_TOKEN_SECRET=
PUBLIC_ACTOR_TOKEN_TTL_SECONDS=3600
WIDGET_INTERNAL_AUTH_ENABLED=true
WIDGET_AUTH_EMAIL_CONFIRMATION_ENABLED=true
WIDGET_AUTH_EMAIL_CONFIRMATION_REDIRECT=http://localhost:5173/app/roadmap
WIDGET_AUTH_PASSWORD_RESET_URL=http://localhost:5173/app/roadmap
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_mailbox@mail.ru
SMTP_PASS=your_app_password
EMAIL_DEFAULT_FROM=your_mailbox@mail.ru
EMAIL_DEFAULT_REPLY_TO=your_mailbox@mail.ru
EMAIL_FROM_NAME=Roadmap Platform

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:1337/api/public
VITE_MANAGER_PANEL_ENABLED=true
VITE_MANAGER_ALLOWED_EMAILS=2102maksim2004@gmail.com
VITE_PUBLIC_WRITE_AUTH_MODE=auth
VITE_BACKEND_BASE_URL=http://localhost:1337
VITE_WIDGET_INTERNAL_AUTH_ENABLED=true


