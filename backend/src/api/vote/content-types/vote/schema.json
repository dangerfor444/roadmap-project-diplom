{
  "kind": "collectionType",
  "collectionName": "votes",
  "info": {
    "singularName": "vote",
    "pluralName": "votes",
    "displayName": "Vote",
    "description": "A single vote for an idea by fingerprint"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "indexes": [
    {
      "name": "votes_idea_fingerprint_unique",
      "columns": ["idea_document_id", "user_fingerprint"],
      "type": "unique"
    }
  ],
  "attributes": {
    "idea": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::idea.idea",
      "inversedBy": "votes",
      "required": true
    },
    "ideaDocumentId": {
      "type": "string",
      "required": true,
      "minLength": 1,
      "maxLength": 64
    },
    "userFingerprint": {
      "type": "string",
      "required": true,
      "minLength": 8,
      "maxLength": 128
    }
  }
}
