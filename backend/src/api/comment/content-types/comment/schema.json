{
  "kind": "collectionType",
  "collectionName": "comments",
  "info": {
    "singularName": "comment",
    "pluralName": "comments",
    "displayName": "Comment",
    "description": "Comments on ideas"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "config": {
    "settings": {
      "searchable": true,
      "filterable": true,
      "bulkable": true,
      "pageSize": 25,
      "mainField": "id",
      "defaultSortBy": "createdAt",
      "defaultSortOrder": "DESC",
      "relationOpenMode": "modal"
    },
    "layouts": {
      "list": ["idea", "isHidden", "createdAt", "userFingerprint"],
      "edit": [
        [
          { "name": "idea", "size": 8 },
          { "name": "isHidden", "size": 4 }
        ],
        [{ "name": "userFingerprint", "size": 12 }],
        [{ "name": "text", "size": 12 }]
      ]
    }
  },
  "indexes": [
    {
      "name": "comments_hidden_created_at_idx",
      "columns": ["is_hidden", "created_at"]
    }
  ],
  "attributes": {
    "idea": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::idea.idea",
      "inversedBy": "comments",
      "required": true
    },
    "text": {
      "type": "text",
      "required": true,
      "minLength": 1,
      "maxLength": 2000
    },
    "userFingerprint": {
      "type": "string",
      "required": true,
      "minLength": 8,
      "maxLength": 128
    },
    "isHidden": {
      "type": "boolean",
      "required": true,
      "default": false
    }
  }
}
